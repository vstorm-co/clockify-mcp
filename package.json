{
  "name": "@jeremyvyska/clockify-mcp",
  "version": "1.0.0",
  "description": "Feature-rich MCP server for Clockify API integration with full CRUD operations",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "clockify",
    "time-tracking",
    "claude",
    "ai",
    "llm",
    "productivity"
  ],
  "author": "Jeremy Vyska <jeremy@vyska.dev>",
  "homepage": "https://github.com/JeremyVyska/clockify-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JeremyVyska/clockify-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/JeremyVyska/clockify-mcp/issues"
  },
  "type": "module",
  "main": "./build/index.js",
  "bin": {
    "clockify-mcp": "./build/index.js"
  },
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepare": "npm run build",
    "prepublishOnly": "npm run lint && npm run build",
    "test": "vitest run",
    "test:create": "npm run build && node build/test-create.js",
    "test:cleanup": "node build/test-cleanup.js",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "build": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "watch": "tsc --watch",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "0.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/node": "^20.17.43",
    "@vitest/ui": "^3.1.3",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-prettier": "^5.4.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.32.0",
    "vitest": "^3.1.3"
  },
  "license": "MIT"
}
